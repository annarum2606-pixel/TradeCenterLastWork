<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — TradeCenter</title>
    <link rel="icon" href="~/icon.ico"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body style="font-family: 'Calibri', sans-serif; background: #FFFFFF; margin: 0; display: flex; flex-direction: column; min-height: 100vh;">

    <header style="background: #FFFFFF; border-bottom: 2px solid #DAA520; padding: 12px 0;">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; gap: 16px;">
            <img src="~/images/icon.png" alt="TradeCenter" height="100"/>
            <h1 style="color: #B8860B; margin: 0; font-size: 26px;">TradeCenter</h1>
        </div>
    </header>

    <main style="flex: 1; max-width: 1200px; width: 100%; margin: 0 auto; padding: 20px; box-sizing: border-box;">
        @RenderBody()
    </main>

    <footer style="background: #DAA520; color: white; text-align: center; padding: 14px 0; font-size: 14px; width: 100%;">
        &copy; 2026 TradeCenter. Все права защищены.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>