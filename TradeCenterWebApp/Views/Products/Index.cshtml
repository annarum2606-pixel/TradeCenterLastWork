@model List<DataLibrary.Models.Product>

<h2>Список товаров</h2>

@foreach (var product in Model)
{
    <div style="border:1px solid black; padding:15px; margin:15px;">
        <h3>@product.Name</h3>
        <p>@product.Description</p>
        <p>Производитель: @product.Manufacturer</p>
        <p><strong>Цена:</strong> @product.Price ₽</p>

        <form method="post" action="/Products/Order">
            <input type="hidden" name="article" value="@product.Article" />
            <button type="submit">
                Заказать
            </button>
        </form>
    </div>
}