<Window x:Class="TradeCenterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeCenterApp"
        mc:Ignorable="d"
        Title="Терминал заказа товаров" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        FontFamily="Calibri"
        Background="#FFFFFF"
        Icon="Images/icon.ico">

    <Grid Margin="10" Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#DAA520" 
                Padding="10" 
                Margin="-10,-10,-10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" 
                       Source="images/icon.png" 
                       Width="100" 
                       Height="50"
                       Margin="0,0,10,0"
                       Stretch="Uniform"/>

                <TextBlock Grid.Column="1" 
                           Text="Терминал заказа товаров" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"/>

                <!--ФИО пользователя-->
                <TextBlock Grid.Column="2" 
                           x:Name="UserFullNameLabel"
                           Text=""
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,15,0"
                           Visibility="Collapsed"/>

                <!--Кнопка для админов и менеджеров-->
                <Button Grid.Column="3"
                        x:Name="OrdersButton"
                        Content="Заказы"
                        Width="80"
                        Height="30"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="12"
                        FontFamily="Calibri"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        Click="OrdersButton_Click"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#B8860B"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#A0750A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!--Кнопка Войти/Выйти-->
                <Button Grid.Column="4"
                        x:Name="AuthButton"
                        Content="Войти"
                        Width="80"
                        Height="30"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="12"
                        FontFamily="Calibri"
                        Cursor="Hand"
                        Click="AuthButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#B8860B"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#A0750A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!--Фильтры и сортировка-->
        <Border Grid.Row="1" 
                Background="#DAA520" 
                Padding="10" 
                Margin="0,0,0,10"
                CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--Поиск, производитель, цена -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Поиск-->
                    <TextBlock Grid.Column="0" 
                               Text="Поиск:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"
                               Foreground="#FFFFFF"/>
                    <TextBox Grid.Column="1" 
                             x:Name="SearchTextBox" 
                             Height="25"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"
                             Background="#FFFFFF"
                             FontFamily="Calibri"/>

                    <!--Производитель-->
                    <TextBlock Grid.Column="3" 
                               Text="Производитель:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="10,0,5,0"
                               Foreground="#FFFFFF"/>
                    <ComboBox Grid.Column="4" 
                              x:Name="ManufacturerComboBox"
                              Height="25"
                              VerticalContentAlignment="Center"
                              SelectionChanged="ManufacturerComboBox_SelectionChanged"
                              Background="#FFFFFF"
                              FontFamily="Calibri"/>

                    <!--Цена-->
                    <TextBlock Grid.Column="6" 
                               Text="Цена от:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="10,0,5,0"
                               Foreground="#FFFFFF"/>
                    <TextBox Grid.Column="7" 
                             x:Name="MinPriceTextBox" 
                             Height="25"
                             Text="0"
                             VerticalContentAlignment="Center"
                             TextChanged="PriceTextBox_TextChanged"
                             Background="#FFFFFF"
                             FontFamily="Calibri"/>

                    <TextBlock Grid.Column="8" 
                               Text="до" 
                               VerticalAlignment="Center"
                               Margin="5,0,75,0"
                               Foreground="#FFFFFF" Grid.ColumnSpan="2"/>

                    <TextBox Grid.Column="8" 
                             x:Name="MaxPriceTextBox" 
                             Height="25"
                             Text="999999"
                             Width="80"
                             VerticalContentAlignment="Center"
                             TextChanged="PriceTextBox_TextChanged"
                             Background="#FFFFFF"
                             FontFamily="Calibri" Grid.ColumnSpan="3" Margin="27,0,146,0"/>
                </Grid>

                <!--Сортировка и счетчик-->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Сортировка-->
                    <TextBlock Grid.Column="0" 
                               Text="Сортировка:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"
                               Foreground="#FFFFFF"/>
                    <ComboBox Grid.Column="1" 
                              x:Name="SortComboBox"
                              Height="25"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SortComboBox_SelectionChanged"
                              Background="#FFFFFF"
                              FontFamily="Calibri">
                        <ComboBoxItem Content="По названию" IsSelected="True"/>
                        <ComboBoxItem Content="По цене"/>
                        <ComboBoxItem Content="По производителю"/>
                    </ComboBox>

                    <CheckBox Grid.Column="3" 
                              x:Name="DescendingCheckBox"
                              Content="По убыванию"
                              VerticalAlignment="Center"
                              Margin="10,0,61,0"
                              Foreground="#FFFFFF"
                              Checked="DescendingCheckBox_Checked"
                              Unchecked="DescendingCheckBox_Unchecked" Grid.ColumnSpan="3"/>

                    <!--Счетчик-->
                    <TextBlock Grid.Column="6" 
                               x:Name="CountLabel"
                               Text="Записей: 0 из 0"
                               VerticalAlignment="Center"
                               Margin="3,0,477,0"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                </Grid>
            </Grid>
        </Border>

        <!--Список товаров-->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      Background="#FFFFFF">
            <ItemsControl x:Name="ProductList" Background="#FFFFFF">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DAA520" 
                                BorderThickness="1" 
                                Padding="10" 
                                Margin="0,5,0,5"
                                Background="#FFFFFF"
                                CornerRadius="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFF5E6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Foreground="#000000"
                                               FontFamily="Calibri"/>

                                    <TextBlock Text="{Binding Description}" 
                                               TextWrapping="Wrap"
                                               Foreground="#000000"
                                               Margin="0,5,0,5"
                                               FontFamily="Calibri"/>

                                    <TextBlock Text="{Binding Manufacturer, StringFormat=Производитель: {0}}"
                                               Foreground="#000000"
                                               FontFamily="Calibri"/>

                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#B8860B"
                                               Margin="0,5,0,0"
                                               FontFamily="Calibri"/>

                                    <TextBlock Text="{Binding Amount, StringFormat=В наличии: {0} шт.}"
                                               Foreground="#000000"
                                               FontSize="12"
                                               FontFamily="Calibri"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Content="Заказать" 
                                        Width="100" 
                                        Height="35" 
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Center"
                                        Background="#B8860B"
                                        Foreground="#FFFFFF"
                                        FontWeight="Bold"
                                        FontSize="12"
                                        FontFamily="Calibri"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#B8860B"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#A0750A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>