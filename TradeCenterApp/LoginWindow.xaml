<Window x:Class="TradeCenterApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeCenterApp"
        mc:Ignorable="d"
        Title="Вход в систему" 
        Height="300" 
        Width="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Calibri"
        Icon="Images/icon.ico"
        Loaded="LoginWindow_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#DAA520" 
                Padding="10" 
                Margin="-20,-20,-20,5">
            
            <TextBlock Text="Вход в систему" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" 
                   Text="Логин:" 
                   FontWeight="Bold"
                   Margin="0,5,0,5"/>
        
        <TextBox Grid.Row="2" 
                 x:Name="LoginTextBox"
                 Height="30"
                 FontFamily="Calibri"
                 FontSize="14"
                 Padding="5"/>

        <TextBlock Grid.Row="3" 
                   Text="Пароль:" 
                   FontWeight="Bold"
                   Margin="0,5,0,5"/>
        
        <PasswordBox Grid.Row="4" 
                     x:Name="PasswordBox"
                     Height="30"
                     FontFamily="Calibri"
                     FontSize="14"
                     Padding="5"/>

        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button x:Name="LoginButton"
                    Content="Войти"
                    Width="100"
                    Height="30"
                    Background="#DAA520"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="16"
                    FontFamily="Calibri"
                    Margin="0,10,10,0"
                    Click="LoginButton_Click">
            </Button>

            <Button Content="Отмена"
                    Width="100"
                    Height="30"
                    Background="#DAA520"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="16"
                    FontFamily="Calibri"
                    Margin="0,10,10,0"
                    Click="CancelButton_Click">
            </Button>
        </StackPanel>
    </Grid>
</Window>