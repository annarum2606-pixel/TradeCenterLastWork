<Window x:Class="TradeCenterApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeCenterApp"
        mc:Ignorable="d"
        Title="Вход в систему" 
        Height="300" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Calibri"
        Background="#FFFFFF"
        Icon="Images/icon.ico"
        Loaded="LoginWindow_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#DAA520" 
                Padding="10" 
                Margin="-20,-20,-20,10">
            <TextBlock Text="Вход в систему" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" 
                   Text="Логин:" 
                   FontWeight="SemiBold"
                   Margin="0,10,0,5"/>
        <TextBox Grid.Row="2" 
                 x:Name="LoginTextBox"
                 Height="30"
                 FontFamily="Calibri"
                 FontSize="14"
                 Padding="5"/>

        <TextBlock Grid.Row="3" 
                   Text="Пароль:" 
                   FontWeight="SemiBold"
                   Margin="0,10,0,5"/>
        <PasswordBox Grid.Row="4" 
                     x:Name="PasswordBox"
                     Height="30"
                     FontFamily="Calibri"
                     FontSize="14"
                     Padding="5"
                     KeyDown="PasswordBox_KeyDown"/>

        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="LoginButton"
                    Content="Войти"
                    Width="100"
                    Height="35"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="14"
                    FontFamily="Calibri"
                    Cursor="Hand"
                    Margin="0,0,10,0"
                    Click="LoginButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#B8860B"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A0750A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Отмена"
                    Width="100"
                    Height="35"
                    Background="#DAA520"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="14"
                    FontFamily="Calibri"
                    Cursor="Hand"
                    Click="CancelButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DAA520"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C49518"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>