<Window x:Class="TradeCenterApp.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeCenterApp"
        mc:Ignorable="d"
        Title="Управление заказами" 
        Height="600"
        Width="1000"
        FontFamily="Calibri"
        WindowStartupLocation="CenterScreen"
        Icon="Images/icon.ico">

    <Grid Margin="10" Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!--Заголовок-->
        <Border Grid.Row="0" 
                Background="#DAA520" 
                Padding="10" 
                Margin="-10,-10,-10,5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" 
                        Source="images/icon.png" 
                        Width="100"
                        Height="50"/>

                <TextBlock Grid.Column="1"
                        Text="Управление заказами" 
                        FontSize="24" 
                        FontWeight="Bold" 
                        VerticalAlignment="Center"
                        Foreground="#FFFFFF"/>
            </Grid>
        </Border>

        <!--Поиск заказа-->
        <Border Grid.Row="1" 
                Background="#DAA520" 
                Padding="10" 
                Margin="0,0,0,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                        Text="ID заказа:" 
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="0,0,5,0"
                        Foreground="#FFFFFF"/>

                <TextBox Grid.Column="1" 
                        x:Name="OrderIdTextBox"
                        Height="20"
                        VerticalContentAlignment="Center"
                        FontFamily="Calibri"/>

                <Button Grid.Column="2"
                        Content="Найти"
                        Width="80"
                        Height="20"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="14"
                        Margin="10,0,0,0"
                        Click="SearchOrder_Click"/>

                <Button Grid.Column="3"
                        Content="Список заказов"
                        Width="120"
                        Height="20"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="14"
                        Margin="10,0,0,0"
                        Click="ShowAllOrders_Click"/>

                <Button Grid.Column="4"
                        Content="Очистить"
                        Width="80"
                        Height="20"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="14"
                        Margin="10,0,0,0"
                        Click="ClearOrder_Click"/>
            </Grid>
        </Border>

        <!--Информация о заказе-->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">

            <Border BorderBrush="#DAA520" 
                    BorderThickness="2" 
                    Padding="15"
                    Margin="0,0,0,10">

                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="ID заказа:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <TextBlock Grid.Column="1" 
                                x:Name="OrderIdText"
                                FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Номер заказа:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <TextBlock Grid.Column="1" 
                                x:Name="OrderNumberText"
                                FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Дата заказа:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <TextBlock Grid.Column="1" 
                                x:Name="OrderDateText"
                                FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Клиент:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <TextBlock Grid.Column="1" 
                                x:Name="CustomerNameText"
                                FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Код получения:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <TextBlock Grid.Column="1" 
                                x:Name="CodeText"
                                FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Статус:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <ComboBox Grid.Column="1" 
                                x:Name="StatusComboBox"
                                Height="20"
                                VerticalContentAlignment="Center"
                                FontFamily="Calibri"
                                SelectionChanged="StatusComboBox_SelectionChanged"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                Text="Дата доставки:" 
                                FontWeight="Bold"
                                FontSize="14"/>
                        
                        <DatePicker Grid.Column="1" 
                                x:Name="DeliveryDatePicker"
                                Height="20"
                                FontFamily="Calibri"
                                SelectedDateChanged="DeliveryDatePicker_SelectedDateChanged"/>
                    </Grid>

                    <Border BorderBrush="#DAA520" 
                            BorderThickness="1" 
                            Padding="10"
                            Margin="0,10,0,0">
                        
                        <StackPanel>
                            <TextBlock Text="Товары в заказе:" 
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Margin="0,0,0,10"/>
                            
                            <ItemsControl x:Name="OrderItemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" 
                                                        Text="{Binding ProductName}"
                                                        FontSize="14"/>
                                            
                                            <TextBlock Grid.Column="1" 
                                                        Text="{Binding Quantity, StringFormat=Кол-во: {0}}"
                                                        FontSize="14"
                                                        Margin="10,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>